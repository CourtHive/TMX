# TMX Assistant — AI chat panel for tournament directors
# Set to the assistant service URL. Leave empty to disable.
# Local dev: http://localhost:3200
# Production (nest): https://assistant.courthive.net
VITE_ASSISTANT_URL=

# Score-relay — Phase 4 crowd promotion UI.
# Used to call score-relay's /api/crowd-sessions/* endpoints from the
# matchUp three-dot menu ("View crowd trackers (N)"). Crowd data never
# transits competition-factory-server (Decision 6).
# Local dev: http://localhost:8384
# Production: https://courthive.net (or wherever score-relay is fronted)
VITE_SCORE_RELAY_URL=
