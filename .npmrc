# Disable pnpm v11 verify-deps-before-run inside scripts/hooks. Lockfiles can
# be briefly stale (package.json edits in flight before pnpm install runs;
# mentat-pull-all.sh deletes lockfiles before each build cycle) so the check
# is noise without added safety in this ecosystem. See pnpm.io/npmrc.
verify-deps-before-run=false
